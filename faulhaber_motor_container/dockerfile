# Use ROS2 Humble as the base image (Ubuntu 22.04)
FROM ros:humble

# Set non-interactive mode
ENV DEBIAN_FRONTEND=noninteractive

# Install basic tools and dependencies
RUN apt-get update && apt-get install -y \
    curl \
    gnupg2 \
    lsb-release \
    python3-pip \
    python3-colcon-common-extensions \
    python3-setuptools \
    build-essential \
    python3-rosdep \
    python3-colcon-ros \
    python3-rosinstall \
    python3-vcstool \
    ros-humble-rclpy \
    ros-humble-geometry-msgs \
    ros-humble-launch \
    ros-humble-launch-ros \
    ros-humble-ament-cmake-python \
    libpython3-dev \
    python3-serial \
 && rm -rf /var/lib/apt/lists/*

# Upgrade pip and install Python dependencies
RUN pip3 install --upgrade pip pyserial

# Create workspace directory
WORKDIR /ros_ws

# (Optional) Initialize rosdep (only if needed for dependencies)
# RUN rosdep init && rosdep update

# Build the ROS2 workspace (will be empty unless code is copied in)
# You can copy your source before building
# COPY src/ ./src/
# RUN /bin/bash -c "source /opt/ros/humble/setup.bash && colcon build"

# Set environment variables
ENV ROS_DISTRO=humble
ENV ROS_WS=/ros_ws
ENV PATH="$PATH:/ros_ws/install/bin"

# Default command to keep the container running
CMD ["/bin/bash"]

